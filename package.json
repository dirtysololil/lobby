{
  "name": "lobby",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "corepack pnpm --filter @lobby/shared build && corepack pnpm --filter @lobby/config build && corepack pnpm --parallel --filter @lobby/shared --filter @lobby/config --filter @lobby/api --filter @lobby/web dev",
    "dev:worker": "corepack pnpm --filter @lobby/api dev:worker",
    "build": "node ./scripts/build.mjs",
    "postinstall": "node ./scripts/prisma-cli.mjs generate --schema prisma/schema.prisma",
    "start:web": "node apps/web/scripts/run-next.mjs start",
    "start:api": "corepack pnpm --filter @lobby/api start:prod",
    "start:worker": "corepack pnpm --filter @lobby/api start:worker",
    "lint": "corepack pnpm --filter @lobby/api lint && corepack pnpm --filter @lobby/web lint",
    "typecheck": "corepack pnpm --filter @lobby/shared build && corepack pnpm --filter @lobby/config build && corepack pnpm --filter @lobby/api exec tsc --noEmit && corepack pnpm --filter @lobby/web exec tsc --noEmit",
    "prisma:generate": "node ./scripts/prisma-cli.mjs generate --schema prisma/schema.prisma",
    "prisma:validate": "node ./scripts/prisma-cli.mjs validate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "node ./scripts/prisma-cli.mjs migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "node ./scripts/prisma-cli.mjs migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:resolve:baseline": "node ./scripts/prisma-cli.mjs migrate resolve --applied 20260402170000_mysql_baseline --schema prisma/schema.prisma",
    "prisma:studio": "node ./scripts/prisma-cli.mjs studio --schema prisma/schema.prisma",
    "db:seed": "corepack pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "prisma": "^6.7.0",
    "typescript": "^5.8.3"
  }
}
