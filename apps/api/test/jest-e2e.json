{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@lobby/shared$": "<rootDir>/../../../packages/shared/src/index.ts",
    "^@lobby/config$": "<rootDir>/../../../packages/config/src/index.ts"
  }
}
